#pragma once

// Copy this file to secrets.h and fill in your values.
// secrets.h is excluded from version control via .gitignore.
//
// Build flags in platformio.ini override all values defined here.

#ifndef FM_DEVICE_NAME
#define FM_DEVICE_NAME "your-device-name"
#endif

// Wi-Fi networks (up to 3). On connection failure the firmware cycles to the
// next network and wraps around to the first again.
// Leave SSID empty ("") to skip that slot.
#ifndef FM_WIFI_SSID_1
#define FM_WIFI_SSID_1 "YourPrimarySSID"
#endif
#ifndef FM_WIFI_PASSWORD_1
#define FM_WIFI_PASSWORD_1 "YourPrimaryPassword"
#endif

#ifndef FM_WIFI_SSID_2
#define FM_WIFI_SSID_2 ""
#endif
#ifndef FM_WIFI_PASSWORD_2
#define FM_WIFI_PASSWORD_2 ""
#endif

#ifndef FM_WIFI_SSID_3
#define FM_WIFI_SSID_3 ""
#endif
#ifndef FM_WIFI_PASSWORD_3
#define FM_WIFI_PASSWORD_3 ""
#endif

#ifndef FM_API_BASE_URL
#define FM_API_BASE_URL "https://your-domain.com"
#endif

#ifndef FM_DEVICE_TOKEN
#define FM_DEVICE_TOKEN "token-from-admin-ui"
#endif

// ESP8266 only: SHA-1 fingerprint of the backend TLS certificate.
// Obtain with:
//   echo | openssl s_client -connect your-domain.com:443 2>/dev/null \
//     | openssl x509 -fingerprint -noout -sha1
#ifndef FM_TLS_CERT_FINGERPRINT
#define FM_TLS_CERT_FINGERPRINT "AA:BB:CC:DD:EE:FF:00:11:22:33:44:55:66:77:88:99:AA:BB:CC:DD"
#endif

// OTA password. Keep non-empty in production.
// FM_OTA_HOSTNAME defaults to FM_DEVICE_NAME if not set.
#ifndef FM_OTA_PASSWORD
#define FM_OTA_PASSWORD "your-ota-password"
#endif
