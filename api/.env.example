APP_NAME=FlatManager API
APP_ENV=development
APP_DEBUG=true
HOST=127.0.0.1
PORT=8000
DOCS_URL=/api/docs
REDOC_URL=/api/redoc
OPENAPI_URL=/api/openapi.json
DATABASE_URL=sqlite:///./data/flatmanager.db
SECURITY_PEPPER=flatmanager-dev-change-me
CODE_HASH_ALGORITHM=sha256
TOKEN_HASH_ALGORITHM=sha256
ADMIN_TOKEN=flatmanager-admin-dev-token
COMMAND_EXPIRATION_SECONDS=10
DEFAULT_OPEN_DURATION_MS=1500
LONG_POLL_TIMEOUT_SECONDS=60
LONG_POLL_POLL_INTERVAL_MS=250
DEVICE_ONLINE_THRESHOLD_SECONDS=90
RATE_LIMIT_WINDOW_SECONDS=300
RATE_LIMIT_IP_MAX_ATTEMPTS=20
RATE_LIMIT_APARTMENT_MAX_ATTEMPTS=50
LOCKOUT_WINDOW_SECONDS=600
LOCKOUT_FAILED_ATTEMPTS_THRESHOLD=5
